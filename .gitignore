# ─── OS FILES ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── PYTHON / BACKEND ────────────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/

# ─── SECRETS & CONFIG (CRITICAL) ─────────────────────────────────────────────
# Never push your API keys (Groq, MongoDB, etc.)
backend/.env
.env

# ─── RAG & STORAGE ───────────────────────────────────────────────────────────
# We keep chroma_store out; the server will generate its own index from your DB
backend/chroma_store/

# ─── USER DATA / UPLOADS ─────────────────────────────────────────────────────
# We block Excel/PDFs to keep the repo clean, but we ALLOW .db for LFS
backend/*.xlsx
backend/*.csv
backend/*.pdf

# ─── FRONTEND ────────────────────────────────────────────────────────────────
node_modules/
.next/
dist/